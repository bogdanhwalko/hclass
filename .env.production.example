APP_NAME=HClass
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=uk
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=uk_UA

LOG_CHANNEL=stack
LOG_LEVEL=error

# Use "mariadb" if the host runs MariaDB (most cPanel boxes do); else "mysql".
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
# cPanel often exposes MySQL only via a unix socket, NOT TCP 127.0.0.1.
# If you get "Connection refused" (2002), set DB_HOST=localhost and the socket:
# DB_SOCKET=/var/lib/mysql/mysql.sock
DB_SOCKET=
# Optional overrides (defaults are fine for most hosts):
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci
# DB_ENGINE=InnoDB
# DB_TIMEZONE=+03:00

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_DRIVER=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_DRIVER=file

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
